# O'Connor Cars — environment variable reference
# Copy this file to .env.local for local development. Never commit .env.local.
#
# All variables below are OPTIONAL. The site builds and runs without any of them.
# Email delivery via the contact form is the only feature gated behind env vars.

# ---------------------------------------------------------------------------
# Contact form email delivery (via Resend — https://resend.com)
# ---------------------------------------------------------------------------

# Your Resend API key. When absent, contact submissions are logged to stdout
# only — the form still returns 200 to the user. Add this when you're ready
# to wire up real email delivery. Get it from: https://resend.com/api-keys
RESEND_API_KEY=

# The "From" address shown on outbound contact notification emails.
# Must be a verified sender domain in your Resend account.
# Defaults to: noreply@oconnorcars.ie
RESEND_FROM_EMAIL=noreply@oconnorcars.ie

# The inbox where contact form submissions are delivered.
# Defaults to: info@oconnorcars.ie
CONTACT_RECIPIENT_EMAIL=info@oconnorcars.ie
